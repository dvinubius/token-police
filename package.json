{
  "name": "token-police",
  "version": "1.0.0",
  "description": "Local dashboard for tracking per-human-request token usage across Claude Code and Codex CLI sessions",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && node start.js",
    "server": "node server.js",
    "test": "node --test",
    "coverage": "c8 --reporter=json node --test && node scripts/sanitize-coverage.js coverage/coverage-final.json",
    "health": "npm run coverage && fallow health --coverage coverage/coverage-final.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "c8": "^11.0.0",
    "fallow": "^2.88.3",
    "svelte": "5.56.2",
    "vite": "8.0.16"
  }
}
