        "panel": "#1c1c1e",
        "panelAlt": "#252528",
        "border": "#35353b"
      },
      "text": {
        "primary": "#ededec",
        "dim": "#a0a0a3",
        "faint": "#6a6a6e"
      },
      "metric": {
