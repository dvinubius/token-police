        "borderWidth": 1,
        "shadow": "0 1px 3px rgba(20,20,17,0.06)"
      },
      "type": {
        "sans": "'Plus Jakarta Sans', system-ui, sans-serif",
        "mono": "'JetBrains Mono', ui-monospace, monospace",
        "display": "'Saira Condensed', system-ui, sans-serif"
      },
      "badge": {
        "claudeCode": { "bg": "rgba(122,69,224,0.13)", "fg": "#6237b3" },
        "codex": { "bg": "rgba(19,138,114,0.13)", "fg": "#0f6e5b" }
      }
    }
  }
}
