      "colorMapping": { "shell": "brand.logo", "inset": "surface.panel", "crest": "surface.panel", "glyph": "surface.panel" },
      "themeAware": true,
      "svgFallback": "If a static asset is needed, render at 2x: <svg viewBox='0 0 32 36'><path d='M16 1.9c2.4 2 5.8 2.8 10.6 2.1-.3 3.5.8 6 3.4 8-2.5 2.7-2.8 8.9-4.7 13-1.7 3.8-5.1 6.6-9.3 8.9-4.2-2.3-7.6-5.1-9.3-8.9C4.8 20.9 4.5 14.7 2 12c2.6-2 3.7-4.5 3.4-8C10.2 4.7 13.6 3.9 16 1.9Z' fill='{brandLogo}'/><path d='M16 5.4c2.1 1.5 4.8 2.2 8.3 1.9.1 2.5 1 4.4 2.6 5.9-1.8 2.8-2.1 7.5-3.6 10.5-1.4 2.7-4 5-7.3 6.9-3.3-1.9-5.9-4.2-7.3-6.9-1.5-3-1.8-7.7-3.6-10.5 1.6-1.5 2.5-3.4 2.6-5.9 3.5.3 6.2-.4 8.3-1.9Z' fill='none' stroke='{panel}' stroke-width='1.7' stroke-linecap='round' stroke-linejoin='round' opacity='0.88'/><path d='M10.7 10.2c1.9.5 3.7.2 5.3-.8 1.6 1 3.4 1.3 5.3.8' fill='none' stroke='{panel}' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round' opacity='0.72'/><text x='16' y='21.5' text-anchor='middle' dominant-baseline='middle' font-family='monospace' font-weight='700' font-size='14' fill='{panel}'>$</text></svg>"
    }
  },
