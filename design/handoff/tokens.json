{
  "$meta": {
    "product": "Token Police",
    "description": "Approved color schemes from the visual-style exploration. Two themes: a dark near-monochrome (graphite) and a warm-white minimal (light). Cost, tokens, and the two model colors are intentionally independent — see visual-system.md.",
    "reference": "Token Police — Style Explorer.dc.html",
    "numbersUseMono": true,
    "numericFontFeature": "tabular-nums",
    "fonts": "Both themes share one typeface pair: Plus Jakarta Sans (sans/UI) + JetBrains Mono (numeric/mono). Saira Condensed is the display face for the wordmark only. Earlier drafts gave Graphite its own IBM Plex pair; the typefaces are now theme-independent."
  },
  "brand": {
    "wordmark": {
      "text": "Token Police",
      "font": "'Saira Condensed', system-ui, sans-serif",
      "weight": 800,
      "transform": "uppercase",
      "letterSpacing": "0.112em",
      "size": "21px",
      "color": "text.primary"
    },
    "tagline": {
      "text": "AGENTIC SURVEILLANCE",
      "font": "mono",
      "size": "9px",
      "transform": "uppercase",
      "letterSpacing": "0.14em",
      "color": "text.faint",
      "note": "Tongue-in-cheek; 7899 is the app's real port."
    },
    "logo": {
      "concept": "Police-style shield badge with a compact crest, inset shield line, and a monospace $ at center.",
      "build": "Inline SVG, 32px by 36px, viewBox 0 0 32 36. Outer shell path uses brand.logo; inset shield stroke uses surface.panel at 1.7px and opacity 0.88; top crest stroke uses surface.panel at 1.4px and opacity 0.72; centered glyph '$' uses mono weight 700 / 14px, x=16, y=20, fill = surface.panel.",
      "replaces": "the previous \u25c6 unicode mark",
      "colorMapping": { "shell": "brand.logo", "inset": "surface.panel", "crest": "surface.panel", "glyph": "surface.panel" },
      "themeAware": true,
      "svgFallback": "If a static asset is needed, render at 2x: <svg viewBox='0 0 32 36'><path d='M16 1.9c2.4 2 5.8 2.8 10.6 2.1-.3 3.5.8 6 3.4 8-2.5 2.7-2.8 8.9-4.7 13-1.7 3.8-5.1 6.6-9.3 8.9-4.2-2.3-7.6-5.1-9.3-8.9C4.8 20.9 4.5 14.7 2 12c2.6-2 3.7-4.5 3.4-8C10.2 4.7 13.6 3.9 16 1.9Z' fill='{brandLogo}'/><path d='M16 5.4c2.1 1.5 4.8 2.2 8.3 1.9.1 2.5 1 4.4 2.6 5.9-1.8 2.8-2.1 7.5-3.6 10.5-1.4 2.7-4 5-7.3 6.9-3.3-1.9-5.9-4.2-7.3-6.9-1.5-3-1.8-7.7-3.6-10.5 1.6-1.5 2.5-3.4 2.6-5.9 3.5.3 6.2-.4 8.3-1.9Z' fill='none' stroke='{panel}' stroke-width='1.7' stroke-linecap='round' stroke-linejoin='round' opacity='0.88'/><path d='M10.7 10.2c1.9.5 3.7.2 5.3-.8 1.6 1 3.4 1.3 5.3.8' fill='none' stroke='{panel}' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round' opacity='0.72'/><text x='16' y='20' text-anchor='middle' dominant-baseline='middle' font-family='monospace' font-weight='700' font-size='14' fill='{panel}'>$</text></svg>"
    },
    "themeSwitcher": {
      "concept": "A single icon-only top-bar toggle that shows the current theme mode.",
      "build": "Use outline sun and moon icons from an icon library. Graphite displays the moon icon; Clean light displays the sun icon. The control is a 32-34px square button, uses text.dim by default, and retints to text.primary / selected border on hover or keyboard focus.",
      "accessibility": "The visible icon is decorative. The button label names the action: 'Switch to light theme' in Graphite and 'Switch to dark theme' in Clean light.",
      "themeAware": true
    }
  },
  "roles": {
    "surface.bg": "App background.",
    "surface.panel": "Cards, top bar, modal, inputs.",
    "surface.panelAlt": "Insets, table headers, and metric cells.",
    "surface.border": "Hairline borders / dividers.",
    "text.primary": "Default text.",
    "text.dim": "Secondary text, labels with content.",
    "text.faint": "Tertiary text, uppercase microlabels, axis ticks.",
    "metric.cost": "Every Estimated-cost value and column.",
    "metric.tokens": "Total-tokens values.",
    "brand.logo": "Shield badge shell.",
    "model.claudeCode": "Claude Code source — chart bars, badge, legend.",
    "model.codex": "Codex source — chart bars, badge, legend.",
    "status.live": "Pulsing live/refresh indicator.",
    "status.hot": "High-cost Human requests and top-20% most expensive LLM calls (hot rows/cells).",
    "status.hotBg": "Hot row background tint.",
    "ui.accent": "UI chrome only: selected border, focus ring.",
    "ui.selectedBg": "Selected session row background.",
    "ui.selectedBorder": "Selected session row border.",
    "shape.radius": "Card/control corner radius.",
    "shape.radiusSmall": "Inset tiles, badges.",
    "shape.borderWidth": "Border thickness (px).",
    "shape.shadow": "Card elevation.",
    "type.sans": "UI / body font.",
    "type.mono": "Numbers, code, timestamps, microlabels."
  },
  "layout": {
    "dialog": {
      "maxWidth": "1280px",
      "topOffset": "100px",
      "desktopPadding": "100px 28px 28px",
      "smallViewportPadding": "12px"
    },
    "prompt": {
      "maxWidth": "600px",
      "fontSize": "13px",
      "lineHeight": "18px",
      "requestClampLines": 3,
      "requestClampHeight": "54px",
      "requestColor": "text.dim",
      "titleRole": "uppercase microlabel"
    },
    "llmCallTable": {
      "layout": "fixed",
      "minWidth": "1160px",
      "columns": {
        "expand": "34px",
        "call": "85px",
        "time": "140px",
        "context": "105px",
        "contextPct": "95px",
        "cacheHit": "105px",
        "freshInput": "105px",
        "cacheRead": "105px",
        "cacheWrite": "95px",
        "output": "95px",
        "totalTokens": "115px",
        "estimatedCost": "125px"
      }
    },
    "llmInsights": {
      "maxWidth": "720px",
      "labelColumn": "180px",
      "gap": "16px",
      "labelFontSize": "11px",
      "valueFontSize": "13px",
      "alignment": "baseline"
    },
    "metricStats": {
      "note": "Three descending tiers of aggregate-metric displays, sized to reflect scope: global (whole dataset) largest, selected-Session totals mid, single Human-request or subagent-task dialog stats smallest. Values use mono + tabular-nums.",
      "global":  { "selector": ".gstat",                "valueFontSize": "26px", "labelFontSize": "11px" },
      "session": { "selector": ".totals-grid .tstat",   "valueFontSize": "18px", "labelFontSize": "11px" },
      "request": { "selector": ".dialog-stats .tstat",  "valueFontSize": "15px", "labelFontSize": "10px" }
    },
    "sessionHierarchy": {
      "note": "Parent Sessions with subagents are collapsed by default. The chevron button below the source badge is the only expand/collapse target; row activation selects the Session.",
      "badgeStack": {
        "selector": ".session-badges",
        "direction": "column",
        "gap": "7px",
        "alignment": "flex-start"
      },
      "chevron": {
        "selector": ".session-chevron",
        "collapsedGlyph": "▾",
        "expandedGlyph": "▴",
        "hitArea": { "width": "28px", "height": "24px" },
        "glyphFontSize": "22px",
        "glyphWeight": 800,
        "color": "color-mix(in srgb, text.primary 82%, text.dim)",
        "background": "transparent",
        "border": "0",
        "radius": "5px",
        "hoverBackground": "color-mix(in srgb, surface.panelAlt 62%, ui.selectedBg)",
        "alignment": "left edge of badge stack"
      },
      "subagentRow": {
        "selector": ".session-row.subagent-row",
        "badgeText": "SUB",
        "indent": "18px * subagent depth",
        "rightEdge": "aligned with parent row"
      }
    },
    "sessionStats": {
      "note": "Selected-Session stats use a tabular metric block rather than independent cards.",
      "container": {
        "selector": ".stats-breakdown",
        "border": "surface.border",
        "radius": "8px"
      },
      "columns": ["Total tokens", "Fresh input", "Output", "Cache read", "Cache write", "Estimated cost"],
      "simpleSession": "one labelled tabular row",
      "parentWithSubagents": ["Total", "Main agent", "one row per subagent"],
      "secondaryRows": {
        "labels": "metric labels omitted",
        "valueFontSize": "14px",
        "colorTreatment": "less saturated metric colors"
      }
    }
  },
  "themes": {
    "graphite": {
      "name": "Graphite",
      "mode": "dark",
      "note": "Near-monochrome chrome; the only chroma in the UI is data + source.",
      "surface": {
