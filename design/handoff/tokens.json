      "text": "AGENTIC SURVEILLANCE",
      "font": "mono",
      "size": "9px",
      "transform": "uppercase",
      "letterSpacing": "0.14em",
      "color": "text.faint",
      "note": "Tongue-in-cheek; 7899 is the app's real port."
    },
    "logo": {
      "concept": "Police-style shield badge with a compact crest, inset shield line, and a monospace $ at center.",
      "build": "Inline SVG, 32px by 36px, viewBox 0 0 32 36. Outer shell path uses brand.logo; inset shield stroke uses surface.panel at 1.7px and opacity 0.88; top crest stroke uses surface.panel at 1.4px and opacity 0.72; centered glyph '$' uses mono weight 700 / 14px, x=16, y=21.5, fill = surface.panel.",
