    "numbersUseMono": true,
    "numericFontFeature": "tabular-nums"
  },
  "brand": {
    "wordmark": {
      "text": "Token Police",
      "font": "'Saira Condensed', system-ui, sans-serif",
      "weight": 800,
      "transform": "uppercase",
      "letterSpacing": "0.05em",
      "size": "21px",
      "color": "text.primary"
